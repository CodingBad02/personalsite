# Ask Sun assistant (server-only — never expose to the client)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override the model if your key uses a different Flash-Lite id
# GEMINI_MODEL=gemini-3.1-flash-lite

# Blog hits + hearts (Upstash Redis — server-only). Without these, the blog
# falls back to per-device localStorage counts.
UPSTASH_REDIS_REST_URL=your_upstash_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
